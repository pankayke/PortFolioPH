android/
ios/
linux/
macos/
windows/

# ── IDE & OS ──────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.iml
.DS_Store
Thumbs.db

# ── Git ───────────────────────────────────────────────────────────────────────
.git/
.gitignore
.gitattributes

# ── Docs & scripts (not part of the app) ─────────────────────────────────────
docs/
scripts/
README.md

# ── Docker files themselves (avoid recursive COPY issues) ────────────────────
Dockerfile
.dockerignore
docker-compose.yml

# ── Test files ────────────────────────────────────────────────────────────────
test/
